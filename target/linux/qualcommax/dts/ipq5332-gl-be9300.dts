/*
 * GL.iNet Flint 3 (GL-BE9300) WiFi 7 router
 *
 * SoC:     Qualcomm IPQ5332 (4x Cortex-A53)
 * RAM:     1 GiB DDR4
 * Storage: 8 GiB eMMC
 * WiFi:    2.4 GHz integrated (IPQ5332)
 *          5 GHz QCN9274 (PCIe)
 *          6 GHz QCN6274 (PCIe)
 * Eth:     1x 2.5 GbE WAN  (RTL8221B over USXGMII)
 *          4x 2.5 GbE LAN  (QCA8084 quad PHY)
 * USB:     1x USB 3.0
 *
 * NOTE: GPIO pin assignments for LEDs and buttons follow the GL.iNet
 *       vendor tree and the Wallys / Qualcomm AP-MI01.6 reference
 *       design. They may need fine-tuning once hardware is on hand.
 */

/dts-v1/;

#include "ipq5332.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "GL.iNet GL-BE9300 (Flint 3)";
	compatible = "glinet,gl-be9300", "qcom,ipq5332";

	aliases {
		serial0 = &blsp1_uart0;
		ethernet0 = &dp1;
		ethernet1 = &dp2;
		label-mac-device = &dp1;
		led-boot = &led_system;
		led-failsafe = &led_system;
		led-running = &led_system;
		led-upgrade = &led_system;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&tlmm 35 GPIO_ACTIVE_LOW>;
			debounce-interval = <60>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_system: system {
			function = LED_FUNCTION_STATUS;
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&tlmm 36 GPIO_ACTIVE_HIGH>;
		};

		wan {
			label = "white:wan";
			function = LED_FUNCTION_WAN;
			color = <LED_COLOR_ID_WHITE>;
			gpios = <&tlmm 37 GPIO_ACTIVE_HIGH>;
		};
	};

	reserved-memory {
		bootloader@4a700000 {
			reg = <0x0 0x4a700000 0x0 0x400000>;
			no-map;
		};

		sbl@4ab00000 {
			reg = <0x0 0x4ab00000 0x0 0x100000>;
			no-map;
		};

		tz_apps@4ac00000 {
			reg = <0x0 0x4ac00000 0x0 0x400000>;
			no-map;
		};
	};
};

&blsp1_uart0 {
	pinctrl-0 = <&uart_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&sdhc {
	bus-width = <8>;
	max-frequency = <384000000>;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	mmc-hs400-enhanced-strobe;
	non-removable;
	pinctrl-0 = <&sdc_default_state>;
	pinctrl-names = "default";
	status = "okay";
};

&tlmm {
	uart_pins: uart-pins {
		pins = "gpio18", "gpio19";
		function = "blsp0_uart0";
		drive-strength = <8>;
		bias-disable;
	};

	mdio_pins: mdio-pins {
		mdc {
			pins = "gpio25";
			function = "mdc";
			drive-strength = <8>;
			bias-pull-up;
		};

		mdio {
			pins = "gpio26";
			function = "mdio";
			drive-strength = <8>;
			bias-pull-up;
		};
	};

	sdc_default_state: sdc-default-state {
		clk-pins {
			pins = "gpio5";
			function = "sdc_clk";
			drive-strength = <8>;
			bias-disable;
		};

		cmd-pins {
			pins = "gpio4";
			function = "sdc_cmd";
			drive-strength = <8>;
			bias-pull-up;
		};

		data-pins {
			pins = "gpio0", "gpio1", "gpio2", "gpio3",
			       "gpio6", "gpio7", "gpio8", "gpio9";
			function = "sdc_data";
			drive-strength = <8>;
			bias-pull-up;
		};

		rclk-pins {
			pins = "gpio10";
			function = "sdc_rclk";
			drive-strength = <8>;
			bias-pull-down;
		};
	};

	pcie0_default: pcie0-default-state {
		clkreq-n-pins {
			pins = "gpio38";
			function = "pcie0_clk";
			drive-strength = <6>;
			bias-pull-up;
		};

		perst-n-pins {
			pins = "gpio39";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
			output-low;
		};

		wake-n-pins {
			pins = "gpio40";
			function = "pcie0_wake";
			drive-strength = <6>;
			bias-pull-up;
		};
	};

	pcie1_default: pcie1-default-state {
		clkreq-n-pins {
			pins = "gpio43";
			function = "pcie1_clk";
			drive-strength = <6>;
			bias-pull-up;
		};

		perst-n-pins {
			pins = "gpio44";
			function = "gpio";
			drive-strength = <8>;
			bias-pull-down;
			output-low;
		};

		wake-n-pins {
			pins = "gpio45";
			function = "pcie1_wake";
			drive-strength = <6>;
			bias-pull-up;
		};
	};
};

&mdio {
	pinctrl-0 = <&mdio_pins>;
	pinctrl-names = "default";
	status = "okay";

	/* QCA8084 quad 2.5G PHY package - LAN ports */
	ethernet-phy-package@0 {
		compatible = "qcom,qca8084-package";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0>;

		qca8084_0: ethernet-phy@1 {
			compatible = "ethernet-phy-ieee802.3-c45";
			reg = <1>;
		};

		qca8084_1: ethernet-phy@2 {
			compatible = "ethernet-phy-ieee802.3-c45";
			reg = <2>;
		};

		qca8084_2: ethernet-phy@3 {
			compatible = "ethernet-phy-ieee802.3-c45";
			reg = <3>;
		};

		qca8084_3: ethernet-phy@4 {
			compatible = "ethernet-phy-ieee802.3-c45";
			reg = <4>;
		};
	};

	/* RTL8221B 2.5G PHY on WAN port */
	rtl8221b: ethernet-phy@1c {
		compatible = "ethernet-phy-ieee802.3-c45";
		reg = <0x1c>;
	};
};

&pcie0 {
	pinctrl-0 = <&pcie0_default>;
	pinctrl-names = "default";

	perst-gpios = <&tlmm 39 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 40 GPIO_ACTIVE_LOW>;
	status = "okay";

	pcie@0 {
		#address-cells = <3>;
		#size-cells = <2>;
		ranges;
		reg = <0 0 0 0 0>;

		wifi0: wifi@0,0 {
			compatible = "pci17cb,1109";
			reg = <0 0 0 0 0>;
			qcom,ath12k-calibration-variant = "GL-iNet-BE9300";
		};
	};
};

&pcie1 {
	pinctrl-0 = <&pcie1_default>;
	pinctrl-names = "default";

	perst-gpios = <&tlmm 44 GPIO_ACTIVE_LOW>;
	wake-gpios = <&tlmm 45 GPIO_ACTIVE_LOW>;
	status = "okay";

	pcie@0 {
		#address-cells = <3>;
		#size-cells = <2>;
		ranges;
		reg = <0 0 0 0 0>;

		wifi1: wifi@0,0 {
			compatible = "pci17cb,1109";
			reg = <0 0 0 0 0>;
			qcom,ath12k-calibration-variant = "GL-iNet-BE9300";
		};
	};
};

&usb {
	status = "okay";
};

&usb_dwc {
	dr_mode = "host";
};

&usb_qmpphy {
	status = "okay";
};

&usb_qusbphy {
	status = "okay";
};

&wifi {
	qcom,ath12k-calibration-variant = "GL-iNet-BE9300";
	status = "okay";
};

/*
 * Ethernet ports. The IPQ5332 EDMA driver exposes ports via the PPE,
 * with QCA8084 as the LAN switch PHY package and RTL8221B as the WAN
 * PHY. dp1/dp2 labels are aliased above for board.d to address them.
 */
&qcom_ppe {
	status = "okay";

	ethernet-ports {
		#address-cells = <1>;
		#size-cells = <0>;

		dp1: port@1 {
			reg = <1>;
			phy-mode = "10g-qxgmii";
			managed = "in-band-status";
			phy-handle = <&qca8084_0>;
			label = "lan1";
			local-mac-address = [00 00 00 00 00 00];
		};

		port@2 {
			reg = <2>;
			phy-mode = "10g-qxgmii";
			managed = "in-band-status";
			phy-handle = <&qca8084_1>;
			label = "lan2";
			local-mac-address = [00 00 00 00 00 00];
		};

		port@3 {
			reg = <3>;
			phy-mode = "10g-qxgmii";
			managed = "in-band-status";
			phy-handle = <&qca8084_2>;
			label = "lan3";
			local-mac-address = [00 00 00 00 00 00];
		};

		port@4 {
			reg = <4>;
			phy-mode = "10g-qxgmii";
			managed = "in-band-status";
			phy-handle = <&qca8084_3>;
			label = "lan4";
			local-mac-address = [00 00 00 00 00 00];
		};

		dp2: port@5 {
			reg = <5>;
			phy-mode = "usxgmii";
			managed = "in-band-status";
			phy-handle = <&rtl8221b>;
			label = "wan";
			local-mac-address = [00 00 00 00 00 00];
		};
	};
};
