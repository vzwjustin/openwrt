#!/bin/sh

. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

ipq53xx_setup_interfaces()
{
	local board="$1"

	case "$board" in
	glinet,gl-be9300)
		ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "wan"
		ucidef_set_network_device_conduit "lan1" "eth0"
		ucidef_set_network_device_conduit "lan2" "eth0"
		ucidef_set_network_device_conduit "lan3" "eth0"
		ucidef_set_network_device_conduit "lan4" "eth0"
		ucidef_set_network_device_conduit "wan" "eth1"
		;;
	*)
		echo "Unsupported hardware. Network interfaces not initialized"
		;;
	esac
}

ipq53xx_setup_macs()
{
	local board="$1"
	local label_mac=""

	case "$board" in
	glinet,gl-be9300)
		label_mac=$(macaddr_canonicalize "$(mtd_get_mac_ascii factory mac)")
		[ -n "$label_mac" ] && {
			ucidef_set_interface_macaddr "wan" "$label_mac"
			ucidef_set_interface_macaddr "lan" "$(macaddr_add "$label_mac" 1)"
		}
		;;
	esac

	[ -n "$label_mac" ] && ucidef_set_label_macaddr "$label_mac"
}

board_config_update
board=$(board_name)
ipq53xx_setup_interfaces $board
ipq53xx_setup_macs $board
board_config_flush

exit 0
