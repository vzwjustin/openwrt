#!/bin/sh

. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

ipq53xx_setup_interfaces()
{
	local board="$1"

	case "$board" in
	glinet,gl-be9300)
		# TODO: wire up real interfaces once the IPQ5332 PPE/EDMA
		# (and QCA8084 + RTL8221B) drivers land. Expected layout:
		#   LAN: lan1 lan2 lan3 lan4  (QCA8084 quad PHY)
		#   WAN: wan                  (RTL8221B)
		# Until then no netdevs exist for this device.
		;;
	*)
		echo "Unsupported hardware. Network interfaces not initialized"
		;;
	esac
}

board_config_update
board=$(board_name)
ipq53xx_setup_interfaces $board
board_config_flush

exit 0
